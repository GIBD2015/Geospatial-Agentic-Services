# GAS Registry local runtime settings.
#
# Copy this file to gas_registry/.env on the machine that runs the registry.
# Do not commit the real gas_registry/.env file after adding a token.
#
# By default, registry POST write APIs and UI registration require an admin
# token. Set GAS_REGISTRY_REQUIRE_ADMIN_TOKEN=false only for trusted local
# development when you intentionally want open write APIs.
GAS_REGISTRY_REQUIRE_ADMIN_TOKEN=false

# When token protection is required, set this to a long random secret. The same
# token must be sent through Authorization: Bearer <token>,
# X-Registry-Admin-Token, or the registry UI Admin Token field.
GAS_REGISTRY_ADMIN_TOKEN=
