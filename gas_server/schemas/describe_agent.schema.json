{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://www.geospatial-agentic-services.online/schemas/describe_agent.schema.json",
  "title": "GAS DescribeAgent Document",
  "type": "object",
  "required": [
    "profile",
    "keywords",
    "skills",
    "execute_task",
    "conformance",
    "provenance_and_reproducibility",
    "governance",
    "extensions"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "profile": {
      "type": "object",
      "required": [
        "agent_id",
        "name",
        "description",
        "version",
        "base_url",
        "provider"
      ],
      "properties": {
        "agent_id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "base_url": {
          "type": "string"
        },
        "last_updated": {
          "type": "string"
        },
        "default_model": {
          "type": [
            "string",
            "null"
          ]
        },
        "provider": {
          "type": "object",
          "required": [
            "name"
          ],
          "properties": {
            "name": {
              "type": "string"
            },
            "website": {
              "type": [
                "string",
                "null"
              ]
            },
            "contacts": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "name"
                ],
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "email": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "role": {
                    "type": [
                      "string",
                      "null"
                    ]
                  }
                },
                "additionalProperties": true
              }
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "keywords": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "skills": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "skill_id",
          "name",
          "description"
        ],
        "properties": {
          "skill_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "constraints": {
            "type": [
              "object",
              "null"
            ]
          }
        },
        "additionalProperties": true
      }
    },
    "execute_task": {
      "type": "object",
      "required": [
        "operation_id",
        "name",
        "description",
        "request_schema",
        "response_schema",
        "modes",
        "task",
        "inputs",
        "outputs",
        "parameters",
        "credentials"
      ],
      "properties": {
        "operation_id": {
          "const": "execute_task"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "request_schema": {
          "type": "string"
        },
        "response_schema": {
          "type": "string"
        },
        "modes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "task": {
          "type": "object",
          "required": [
            "instructions"
          ],
          "properties": {
            "instructions": {
              "$ref": "#/$defs/field_description"
            }
          },
          "additionalProperties": true
        },
        "inputs": {
          "type": "object",
          "additionalProperties": true
        },
        "outputs": {
          "type": "object",
          "required": [
            "artifact_delivery",
            "primary_artifacts"
          ],
          "properties": {
            "artifact_delivery": {
              "type": "object",
              "required": [
                "required",
                "default",
                "allowed_values",
                "description"
              ],
              "properties": {
                "required": {
                  "type": "boolean"
                },
                "default": {
                  "type": "string"
                },
                "allowed_values": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string"
                  }
                },
                "description": {
                  "type": "string"
                }
              },
              "additionalProperties": true
            },
            "primary_artifacts": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": true
              }
            }
          },
          "additionalProperties": true
        },
        "parameters": {
          "type": "object",
          "additionalProperties": true
        },
        "credentials": {
          "type": "object",
          "required": [
            "required",
            "one_of",
            "description"
          ],
          "properties": {
            "required": {
              "type": "boolean"
            },
            "one_of": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string"
              }
            },
            "description": {
              "type": "string"
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "conformance": {
      "type": "object",
      "required": [
        "gas_version",
        "schemas"
      ],
      "properties": {
        "gas_version": {
          "type": "string"
        },
        "schemas": {
          "type": "object",
          "required": [
            "describe_agent",
            "execute_task_request",
            "task_response"
          ],
          "properties": {
            "describe_agent": {
              "type": "string"
            },
            "execute_task_request": {
              "type": "string"
            },
            "task_response": {
              "type": "string"
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "provenance_and_reproducibility": {
      "type": "object",
      "properties": {
        "provenance": {
          "$ref": "#/$defs/support_statement"
        },
        "reproducibility": {
          "$ref": "#/$defs/support_statement"
        },
        "validation": {
          "$ref": "#/$defs/support_statement"
        }
      },
      "additionalProperties": true
    },
    "governance": {
      "type": "object"
    },
    "extensions": {
      "type": "object"
    }
  },
  "$defs": {
    "field_description": {
      "type": "object",
      "required": [
        "required",
        "description"
      ],
      "properties": {
        "required": {
          "type": "boolean"
        },
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "support_statement": {
      "type": "object",
      "required": [
        "supported",
        "description"
      ],
      "properties": {
        "supported": {
          "type": "boolean"
        },
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
