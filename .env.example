# Optional local defaults for the built-in model-backed example agents.
#
# GAS itself does not require these exact credential names. New agent
# developers should document their own required credentials in the agent's
# DescribeAgent capability JSON. Credentials are normally supplied by service
# consumers at request time.
OPENAI_API_KEY=
GIBD_API_KEY=

# Local development server URL used by examples and client scripts.
GAS_BASE_URL=http://127.0.0.1:4042
